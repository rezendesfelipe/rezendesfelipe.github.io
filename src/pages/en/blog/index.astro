---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import LanguageToggle from '../../../components/LanguageToggle.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';
import logo from '../../../assets/logo_variation_4.png';

const allPosts = (await getCollection('blog', (p) => (p.data.lang ?? 'pt') === 'en' && !p.data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = allPosts[0];
const restPosts = allPosts.slice(1);

const TOP_CATEGORIES = [
  'Cloud & DevOps',
  'Tutorials',
  'Customer Stories',
  'Security',
  'Platform Engineering',
  'SRE & Observability',
  'FinOps',
  'AI & MLOps',
];

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <header class="topbar">
      <nav class="topbar__nav">
        <a class="topbar__brand" href="/en/"><img src={logo.src} alt="Felipe Rezende" class="topbar__logo" /></a>
        <div class="topbar__links">
          <a href="/en/">Home</a>
          <a href="/en/blog/">Blog</a>
          <a href="/en/#case-studies">Case Studies</a>
          <a href="/en/#contact">Contact</a>
          <LanguageToggle />
        </div>
      </nav>
    </header>

    <!-- Blog Hero -->
    <div class="blog-hero">
      <div class="blog-hero__inner container-wide">
        <p class="blog-hero__eyebrow">Blog</p>
        <h1 class="blog-hero__title">Cloud, DevOps & Platform Engineering</h1>
        <p class="blog-hero__subtitle">
          Technical articles, step-by-step tutorials and case studies on cloud
          infrastructure, automation and SRE.
        </p>
        <div class="blog-search blog-hero__search">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="search" id="search" placeholder="Search articles..." autocomplete="off" aria-label="Search articles" />
        </div>
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="blog-cats-bar">
      <div class="container-wide">
        <div class="blog-cats" id="cat-filter" role="tablist" aria-label="Filter by category">
          <button class="blog-cat blog-cat--active" data-cat="" role="tab" aria-selected="true">All</button>
          {TOP_CATEGORIES.map((cat) => (
            <button class="blog-cat" data-cat={cat} role="tab" aria-selected="false">{cat}</button>
          ))}
        </div>
      </div>
    </div>

    <main class="container-wide blog-main">
      {featured && (
        <section class="blog-featured" aria-label="Featured article">
          <a href={`/en/blog/${featured.id}/`} class="blog-featured__card"
             data-cat={featured.data.category ?? ''}
             data-tags={(featured.data.tags ?? []).join(',')}
             data-title={featured.data.title.toLowerCase()}
             data-desc={(featured.data.description ?? '').toLowerCase()}>
            <div class="blog-featured__image" aria-hidden="true">
              {featured.data.heroImage
                ? <img src={(featured.data.heroImage as any).src} alt="" />
                : <div class="blog-featured__image-placeholder"><span>📝</span></div>
              }
            </div>
            <div class="blog-featured__body">
              <div class="blog-featured__meta">
                {featured.data.category && <span class="blog-cat-badge">{featured.data.category}</span>}
                <span class="blog-featured__reading">{featured.data.readingTime ?? '5 min read'}</span>
              </div>
              <h2 class="blog-featured__title">{featured.data.title}</h2>
              <p class="blog-featured__desc">{featured.data.description}</p>
              <div class="blog-post-footer">
                <div class="blog-author-mini">
                  <div class="blog-author-mini__avatar" aria-hidden="true">{featured.data.author?.name?.[0] ?? 'F'}</div>
                  <div>
                    <span class="blog-author-mini__name">{featured.data.author?.name ?? 'Felipe Rezende'}</span>
                    <span class="blog-author-mini__date">· <FormattedDate date={featured.data.pubDate} /></span>
                  </div>
                </div>
                {(featured.data.tags ?? []).length > 0 && (
                  <ul class="tags"><>{(featured.data.tags ?? []).slice(0, 3).map((t) => <li class="tag">{t}</li>)}</></ul>
                )}
              </div>
            </div>
          </a>
        </section>
      )}

      {allTags.length > 0 && (
        <div class="blog-tag-strip" id="tag-filter" aria-label="Filter by tag">
          <span class="blog-tag-strip__label">Tags:</span>
          <button class="tag tag--active" data-tag="">All</button>
          {allTags.map((tag) => <button class="tag" data-tag={tag}>{tag}</button>)}
        </div>
      )}

      <section aria-label="Articles">
        <ul class="blog-grid" id="post-list">
          {restPosts.map((post) => (
            <li class="blog-card"
                data-cat={post.data.category ?? ''}
                data-tags={(post.data.tags ?? []).join(',')}
                data-title={post.data.title.toLowerCase()}
                data-desc={(post.data.description ?? '').toLowerCase()}>
              <a href={`/en/blog/${post.id}/`} class="blog-card__link">
                <div class="blog-card__image" aria-hidden="true">
                  {post.data.heroImage
                    ? <img src={(post.data.heroImage as any).src} alt="" />
                    : <div class="blog-card__image-placeholder"><span>📄</span></div>
                  }
                </div>
                <div class="blog-card__body">
                  <div class="blog-card__meta">
                    {post.data.category && <span class="blog-cat-badge">{post.data.category}</span>}
                    {post.data.readingTime && <span class="blog-card__reading">{post.data.readingTime}</span>}
                  </div>
                  <h3 class="blog-card__title">{post.data.title}</h3>
                  <p class="blog-card__desc">{post.data.description}</p>
                  <div class="blog-post-footer">
                    <div class="blog-author-mini">
                      <div class="blog-author-mini__avatar" aria-hidden="true">{post.data.author?.name?.[0] ?? 'F'}</div>
                      <div>
                        <span class="blog-author-mini__name">{post.data.author?.name ?? 'Felipe Rezende'}</span>
                        <span class="blog-author-mini__date">· <FormattedDate date={post.data.pubDate} /></span>
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
        <p id="no-results" class="muted" style="display:none;margin-top:2rem;text-align:center;">No articles found.</p>
      </section>

      <section class="newsletter-cta" aria-label="Newsletter">
        <div class="newsletter-cta__inner">
          <div class="newsletter-cta__icon" aria-hidden="true">📬</div>
          <div class="newsletter-cta__copy">
            <h2 class="newsletter-cta__title">Stay in the loop</h2>
            <p class="newsletter-cta__desc">New articles on Cloud, DevOps and Platform Engineering — subscribe via RSS or follow on LinkedIn.</p>
          </div>
          <div class="newsletter-cta__actions">
            <a href="/rss.xml" class="btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
              RSS Feed
            </a>
            <a href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener" class="btn btn--ghost">LinkedIn</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer container-wide">
      <div class="footer__bottom">
        <p class="footer__copy">© {new Date().getFullYear()} Felipe Rezende</p>
        <span class="footer__made">built with <a href="https://astro.build" target="_blank" rel="noopener">astro</a></span>
      </div>
    </footer>

    <script>
      const searchInput = document.getElementById('search') as HTMLInputElement | null;
      const catButtons = document.querySelectorAll<HTMLButtonElement>('#cat-filter [data-cat]');
      const tagButtons = document.querySelectorAll<HTMLButtonElement>('#tag-filter [data-tag]');
      const items = document.querySelectorAll<HTMLElement>('#post-list .blog-card');
      const featured = document.querySelector<HTMLElement>('.blog-featured__card');
      const noResults = document.getElementById('no-results');
      let activeCat = '';
      let activeTag = '';

      function filter() {
        const q = searchInput?.value.toLowerCase().trim() ?? '';
        let visible = 0;
        items.forEach((item) => {
          const match = (!q || (item.dataset.title ?? '').includes(q) || (item.dataset.desc ?? '').includes(q))
            && (!activeCat || item.dataset.cat === activeCat)
            && (!activeTag || (item.dataset.tags ?? '').split(',').includes(activeTag));
          item.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        if (featured) {
          const fmatch = (!q || (featured.dataset.title ?? '').includes(q) || (featured.dataset.desc ?? '').includes(q))
            && (!activeCat || featured.dataset.cat === activeCat)
            && (!activeTag || (featured.dataset.tags ?? '').split(',').includes(activeTag));
          (featured.closest('.blog-featured') as HTMLElement | null)?.style?.setProperty('display', fmatch ? '' : 'none');
          if (fmatch) visible++;
        }
        if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
      }

      searchInput?.addEventListener('input', filter);
      catButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeCat = btn.dataset.cat ?? '';
          catButtons.forEach((b) => { b.classList.remove('blog-cat--active'); b.setAttribute('aria-selected', 'false'); });
          btn.classList.add('blog-cat--active'); btn.setAttribute('aria-selected', 'true');
          filter();
        });
      });
      tagButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeTag = btn.dataset.tag ?? '';
          tagButtons.forEach((b) => b.classList.remove('tag--active'));
          btn.classList.add('tag--active');
          filter();
        });
      });
    </script>
  </body>
</html>
