---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', (p) => (p.data.lang ?? 'pt') === 'en' && !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const secondaryPosts = posts.slice(1, 3);

const featuredProjects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .slice(0, 3);
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description="DevOps and Cloud portfolio and study blog." />
  </head>
  <body>
    <SiteNav lang="en" active="home" />

    <header class="home-hero">
      <div class="home-hero__grid container-wide">
        <div class="home-hero__content">
          <div class="home-hero__badge">Available for cloud architecture and modernization</div>
          <h1 class="home-hero__title">Felipe <span>Rezende</span></h1>
          <p class="home-hero__subtitle">Cloud Architect</p>
          <p class="home-hero__desc">
            Designing resilient cloud infrastructures and automated delivery pipelines for modern environments.
          </p>
          <div class="home-hero__actions">
            <a class="btn" href="#projects">Explore Projects</a>
            <a class="btn btn--ghost" href="/en/about/">View Roadmap</a>
          </div>
          <div class="hero-stats">
            <div>
              <div class="hero-stats__value">8+</div>
              <div class="hero-stats__label">Years Exp</div>
            </div>
            <div>
              <div class="hero-stats__label">Cloud Stack</div>
              <div class="hero-stats__icons">☁️ ⚙️ 🚀</div>
            </div>
          </div>
        </div>

        <div class="home-hero__media">
          <img src="/profile.jpg" alt="Felipe Rezende" />
        </div>
      </div>
    </header>

    <main class="container-wide">
      <section id="projects" class="section">
        <div class="section__header">
          <h2>Innovative Projects</h2>
        </div>
        <ul class="blog-grid">
          {featuredProjects.map((project) => (
            <li class="blog-card">
              <a href={project.data.url} target="_blank" rel="noopener" class="blog-card__link">
                <div class="blog-card__body">
                  <div class="project-tags">
                    {(project.data.tags ?? []).slice(0, 2).map((tag) => <span>{tag}</span>)}
                  </div>
                  <h3 class="blog-card__title">{project.data.title}</h3>
                  <p class="blog-card__desc">{project.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="section">
        <div class="section__header">
          <h2>Latest insights</h2>
          <a class="link" href="/en/blog/">View all →</a>
        </div>

        {featuredPost && (
          <a href={`/en/blog/${featuredPost.id}/`} class="blog-featured__card">
            <div class="blog-featured__image">
              {featuredPost.data.heroImage
                ? <img src={(featuredPost.data.heroImage as any).src} alt="" />
                : <div class="blog-featured__image-placeholder"><span>📝</span></div>}
            </div>
            <div class="blog-featured__body">
              <h3 class="blog-featured__title">{featuredPost.data.title}</h3>
              <p class="blog-featured__desc">{featuredPost.data.description}</p>
            </div>
          </a>
        )}

        <ul class="home-posts-grid home-posts-grid--compact" style="margin-top:1.5rem;">
          {secondaryPosts.map((post) => (
            <li>
              <a href={`/en/blog/${post.id}/`} class="blog-card__link">
                <div class="blog-card__body">
                  <h3 class="blog-card__title">{post.data.title}</h3>
                  <p class="blog-card__desc">{post.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>

    <SiteFooter lang="en" />
  </body>
</html>

<style>
  .home-hero {
    min-height: calc(100vh - 96px);
    padding: 7.5rem 0 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .home-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(47, 217, 244, 0.2) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.15;
    pointer-events: none;
  }
  .home-hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: center;
  }
  .home-hero__badge {
    display: inline-block;
    padding: .45rem .85rem;
    background: rgba(34, 42, 61, .7);
    border-left: 4px solid var(--primary);
    border-radius: .5rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .7rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .home-hero__title {
    margin: 0;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: .92;
  }
  .home-hero__title span { color: var(--primary); display: block; }
  .home-hero__subtitle {
    margin: 1rem 0 .5rem;
    font-size: 1.7rem;
    color: var(--muted);
    font-family: var(--font-display);
  }
  .home-hero__desc {
    max-width: 58ch;
    color: var(--muted);
    font-size: 1.05rem;
  }
  .home-hero__actions {
    margin-top: 1.5rem;
    display: flex;
    gap: .85rem;
    flex-wrap: wrap;
  }
  .hero-stats {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(69, 70, 77, 0.35);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    max-width: 420px;
  }
  .hero-stats__value {
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--primary);
  }
  .hero-stats__label {
    font-size: .68rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
  }
  .hero-stats__icons { margin-top: .45rem; font-size: 1rem; }

  .project-tags {
    display: flex;
    gap: .4rem;
    margin-bottom: .65rem;
    flex-wrap: wrap;
  }
  .project-tags span {
    padding: .15rem .45rem;
    font-size: .62rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    border: 1px solid rgba(47, 217, 244, 0.2);
    color: var(--primary);
    border-radius: .2rem;
    background: rgba(47, 217, 244, 0.08);
  }

  .home-posts-grid--compact .blog-card__body {
    min-height: 132px;
  }
  .home-hero__media {
    border-radius: .75rem;
    overflow: hidden;
    background: var(--surface-container-high);
    box-shadow: var(--ambient-shadow);
  }
  .home-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(.15) contrast(1.05);
  }

  @media (max-width: 940px) {
    .home-hero__grid { grid-template-columns: 1fr; }
    .home-hero { min-height: auto; }
  }
</style>
