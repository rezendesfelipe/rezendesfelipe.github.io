---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Card from '../../components/Card.astro';
import { arsenal } from '../../data/stack';
import ArsenalCard from '../../components/ArsenalCard.astro';
import { SITE_TITLE } from '../../consts';
import LanguageToggle from '../../components/LanguageToggle.astro';
import logo from '../../assets/logo_variation_4.png';

const lang = 'en';

const posts = (await getCollection('blog', (p) => (p.data.lang ?? 'pt') === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const projects = (await getCollection('projects', (p) => (p.data.lang ?? 'pt') === lang))
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const certs = (await getCollection('certifications', (c) => (c.data.lang ?? 'pt') === lang))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description="DevOps and Cloud portfolio and study blog." />
  </head>
  <body>
    <header class="topbar">
      <nav class="topbar__nav">
        <a class="topbar__brand" href="/en/"><img src={logo.src} alt="Felipe Rezende" class="topbar__logo" /></a>
        <div class="topbar__links">
          <a href="#case-studies">Case Studies</a>
          <a href="#certifications">Certifications</a>
          <a href="#arsenal">Technical Arsenal</a>
          <a href="/en/blog/">Blog</a>
          <a href="#contact">Contact</a>
          <LanguageToggle />
        </div>
      </nav>
    </header>

    <main class="container">
      <!-- ── Section 1: Hero ── -->
      <section class="hero">
        <div class="hero__inner">
          <div class="hero__content">
            <h1 class="hero__name"><span>Felipe Rezende</span></h1>
            <p class="hero__role">Cloud and DevOps Architect</p>
            <p class="hero__about">
              Cloud infrastructure specialist focused on automation and observability.
              Passionate about turning complex environments into reliable, scalable, and
              well-documented systems — with AWS, Azure, Terraform, Kubernetes, and more.
            </p>
            <div class="hero__social">
              <a href="https://github.com/rezendesfelipe" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                GitHub
              </a>
              <a href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
              <a href="mailto:frezende21@gmail.com">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                Email
              </a>
            </div>
          </div>
          <div class="hero__photo" aria-label="Felipe Rezende's photo">
            <!-- Replace with your photo: <img src="/foto.jpg" alt="Felipe Rezende" /> -->
            <span>Your<br/>photo<br/>here</span>
          </div>
        </div>
      </section>

      <!-- ── Section 2: Recent Articles ── -->
      <section class="section">
        <div class="section__header">
          <h2>Recent Articles</h2>
          <a class="link" href="/en/blog/">View all →</a>
        </div>

        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/en/blog/${post.id}/`}>
                <h3>{post.data.title}</h3>
                <p class="muted post-desc">{post.data.description}</p>
                <p class="muted post-date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- ── Section: Case Studies ── -->
      <section class="section" id="case-studies">
        <div class="section__header">
          <h2>Case Studies</h2>
        </div>

        <div class="grid">
          {projects.map((p) => (
            <Card href={p.data.url}>
              <h3 class="card__title">{p.data.title}</h3>
              <p class="muted card__desc">{p.data.description}</p>
              {p.data.tags?.length ? (
                <ul class="tags">
                  {p.data.tags.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
              ) : null}
            </Card>
          ))}
        </div>
      </section>

      <!-- ── Section: Certifications ── -->
      <section class="section" id="certifications">
        <div class="section__header">
          <h2>Certifications</h2>
        </div>

        <div class="grid">
          {certs.map((c) => (
            <Card href={c.data.url}>
              <h3 class="card__title">{c.data.title}</h3>
              <p class="muted card__desc">{c.data.issuer}</p>
            </Card>
          ))}
        </div>
      </section>

      <!-- ── Section: Technical Arsenal ── -->
      <section class="section" id="arsenal">
        <div class="section__header">
          <h2>{arsenal.en.title}</h2>
        </div>

        <div class="grid grid--stack">
          {arsenal.en.categories.map((cat) => (
            <ArsenalCard
              icon={cat.icon}
              label={cat.label}
              subtitle={cat.subtitle}
              items={cat.items}
              highlight={cat.highlight}
            />
          ))}
        </div>
      </section>

      <!-- ── Section: Contact ── -->
      <section class="section" id="contact">
        <div class="section__header">
          <h2>Contact</h2>
        </div>

        <div class="grid">
          <Card href="mailto:frezende21@gmail.com">
            <h3 class="card__title">Email</h3>
            <p class="muted card__desc">frezende21@gmail.com</p>
          </Card>
          <Card href="https://www.linkedin.com/in/rezendesfelipe/">
            <h3 class="card__title">LinkedIn</h3>
            <p class="muted card__desc">Connect with me</p>
          </Card>
          <Card href="https://github.com/rezendesfelipe">
            <h3 class="card__title">GitHub</h3>
            <p class="muted card__desc">@rezendesfelipe</p>
          </Card>
        </div>
      </section>
    </main>

    <!-- ── Footer ── -->
    <footer class="footer container">
      <div class="footer__grid">
        <div>
          <p class="footer__brand-name">Felipe Rezende</p>
          <p class="footer__tagline">Cloud and DevOps Architect.<br/>Building reliable infrastructure.</p>
        </div>
        <div>
          <p class="footer__col-title">Navigation</p>
          <ul class="footer__links">
            <li><a href="/en/">Home</a></li>
            <li><a href="/en/blog/">Blog</a></li>
            <li><a href="#case-studies">Case Studies</a></li>
            <li><a href="#certifications">Certifications</a></li>
          </ul>
        </div>
        <div>
          <p class="footer__col-title">Content</p>
          <ul class="footer__links">
            <li><a href="/en/blog/">Articles</a></li>
            <li><a href="#arsenal">Technical Arsenal</a></li>
            <li><a href="/rss.xml">RSS Feed</a></li>
            <li><a href="/sitemap-index.xml">Sitemap</a></li>
          </ul>
        </div>
        <div>
          <p class="footer__col-title">Contact</p>
          <ul class="footer__links">
            <li><a href="https://github.com/rezendesfelipe" target="_blank" rel="noopener">GitHub</a></li>
            <li><a href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href="mailto:frezende21@gmail.com">Email</a></li>
          </ul>
        </div>
      </div>
      <div class="footer__bottom">
        <p class="footer__copy">© {new Date().getFullYear()} Felipe Rezende. All rights reserved.</p>
        <span class="footer__made">built with <a href="https://astro.build" target="_blank" rel="noopener">astro</a></span>
      </div>
    </footer>
  </body>
</html>
