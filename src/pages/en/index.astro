---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Card from '../../components/Card.astro';
import { stack } from '../../data/stack';
import { SITE_TITLE } from '../../consts';
import LanguageToggle from '../../components/LanguageToggle.astro';

const lang = 'en';

const posts = (await getCollection('blog', (p) => (p.data.lang ?? 'pt') === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const projects = (await getCollection('projects', (p) => (p.data.lang ?? 'pt') === lang))
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const certs = (await getCollection('certifications', (c) => (c.data.lang ?? 'pt') === lang))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description="DevOps Engineer portfolio and study blog." />
  </head>
  <body>
    <main class="container">
      <header class="topbar">
        <nav class="topbar__nav">
          <a class="topbar__brand" href="/en/">Felipe Rezende</a>
          <div class="topbar__links">
            <a href="#projects">Projects</a>
            <a href="#certifications">Certifications</a>
            <a href="#stack">Stack</a>
            <a href="#contact">Contact</a>
            <LanguageToggle />
          </div>
        </nav>
      </header>

      <section class="hero">
        <p class="muted">DevOps Engineer</p>
        <h1>Building reliable, automated, and observable infrastructure.</h1>
        <p class="hero__subtitle">
          I document my studies and share projects about cloud, IaC, CI/CD, Kubernetes, and observability.
        </p>

        <div class="hero__actions">
          <a class="btn" href="/en/blog/">Read articles</a>
          <a class="btn btn--ghost" href="#contact">Contact</a>
        </div>

        <div class="hero__meta">
          <a href="https://github.com/rezendesfelipe">GitHub</a>
          <span aria-hidden="true">·</span>
          <a href="https://www.linkedin.com/in/SEU_LINKEDIN/">LinkedIn</a>
          <span aria-hidden="true">·</span>
          <a href="mailto:SEU_EMAIL_AQUI">Email</a>
        </div>
      </section>

      <section class="section" id="projects">
        <div class="section__header">
          <h2>Projects</h2>
        </div>

        <div class="grid">
          {projects.map((p) => (
            <Card href={p.data.url}>
              <h3 class="card__title">{p.data.title}</h3>
              <p class="muted">{p.data.description}</p>
              {p.data.tags?.length ? (
                <ul class="tags">
                  {p.data.tags.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
              ) : null}
            </Card>
          ))}
        </div>
      </section>

      <section class="section" id="certifications">
        <div class="section__header">
          <h2>Certifications</h2>
        </div>

        <div class="grid">
          {certs.map((c) => (
            <Card href={c.data.url}>
              <h3 class="card__title">{c.data.title}</h3>
              <p class="muted">{c.data.issuer}</p>
            </Card>
          ))}
        </div>
      </section>

      <section class="section" id="stack">
        <div class="section__header">
          <h2>{stack.en.title}</h2>
        </div>

        <div class="grid grid--stack">
          {stack.en.items.map((i) => (
            <Card>
              <h3 class="card__title">{i.label}</h3>
              <p class="muted">{i.value}</p>
            </Card>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="section__header">
          <h2>Latest articles</h2>
          <a class="link" href="/en/blog/">View all</a>
        </div>

        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/en/blog/${post.slug}/`}>
                <h3>{post.data.title}</h3>
                <p class="muted">{post.data.description}</p>
                <p class="muted"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="section" id="contact">
        <div class="section__header">
          <h2>Contact</h2>
        </div>

        <div class="grid">
          <Card href="mailto:SEU_EMAIL_AQUI">
            <h3 class="card__title">Email</h3>
            <p class="muted">SEU_EMAIL_AQUI</p>
          </Card>
          <Card href="https://www.linkedin.com/in/SEU_LINKEDIN/">
            <h3 class="card__title">LinkedIn</h3>
            <p class="muted">Connect with me</p>
          </Card>
          <Card href="https://github.com/rezendesfelipe">
            <h3 class="card__title">GitHub</h3>
            <p class="muted">@rezendesfelipe</p>
          </Card>
        </div>
      </section>

      <footer class="footer">
        <p class="muted">© {new Date().getFullYear()} Felipe Rezende</p>
      </footer>
    </main>
  </body>
</html>