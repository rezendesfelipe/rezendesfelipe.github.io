---
import BaseHead from '../../components/BaseHead.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import cvFile from '../../assets/CV_CA_FELIPE-REZENDE_ENG_26.pdf';
import { SITE_TITLE } from '../../consts';
---

<html lang="en">
  <head>
    <BaseHead title={`About · ${SITE_TITLE}`} description="About Felipe Rezende, trajectory and certifications." />
  </head>
  <body>
    <SiteNav lang="en" active="about" />

    <main class="about-page">
      <section class="about-hero container-wide">
        <div>
          <p class="about-kicker">Cloud Infrastructure Architect</p>
          <h1>Architecting <span>Resilient</span> Digital Foundations.</h1>
          <p>
            Felipe Rezende is a Cloud Infrastructure Architect focused on Azure, with experience in multi-cloud,
            automation, security and platform engineering.
          </p>
          <div class="about-actions">
            <a class="btn" href={cvFile} download>Download CV</a>
            <a class="btn btn--ghost" href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener">Connect on LinkedIn</a>
          </div>
        </div>
        <div class="about-photo">
          <img src="/profile.jpg" alt="Felipe Rezende" />
        </div>
      </section>

      <section class="section container-wide">
        <div class="section__header"><h2>Professional Timeline</h2></div>
        <div class="timeline">
          <article class="timeline__item">
            <span class="timeline__dot"></span>
            <div class="timeline__content">
              <p class="timeline__period">Dec 2025 - Present</p>
              <h3>Senior Cloud Consultant · SoftwareOne</h3>
              <p>Driving cloud transformation initiatives and enterprise architecture design at scale.</p>
            </div>
          </article>
          <article class="timeline__item">
            <span class="timeline__dot"></span>
            <div class="timeline__content">
              <p class="timeline__period">Jul 2025 - Nov 2025</p>
              <h3>Cloud Solutions Architect Lead · Mars</h3>
              <p>Led Azure-native migration architecture and modernization strategies for enterprise systems.</p>
            </div>
          </article>
          <article class="timeline__item">
            <span class="timeline__dot"></span>
            <div class="timeline__content">
              <p class="timeline__period">Feb 2023 - Apr 2025</p>
              <h3>Team Lead · SoftwareOne</h3>
              <p>Mentored architecture squads and supported mission-critical multi-cloud environments.</p>
            </div>
          </article>
          <article class="timeline__item">
            <span class="timeline__dot timeline__dot--alt"></span>
            <div class="timeline__content timeline__content--dashed">
              <p class="timeline__period">May 2024 - Dec 2025</p>
              <h3>Teacher · FIAP</h3>
              <p>Teaching cloud architecture and platform engineering for upcoming professionals.</p>
            </div>
          </article>
        </div>
      </section>

      <section class="section container-wide">
        <div class="section__header"><h2>Certifications and Stack</h2></div>
        <div class="about-chips">
          <span>AWS Solutions Architect – Professional</span>
          <span>Google Professional Cloud Architect</span>
          <span>Azure Solutions Architect Expert (AZ-305)</span>
          <span>DevOps Engineer Expert (AZ-400)</span>
          <span>Terraform</span>
          <span>Kubernetes (AKS)</span>
          <span>GitHub Actions</span>
          <span>Azure Governance</span>
        </div>
      </section>
    </main>

    <SiteFooter lang="en" />
  </body>
</html>

<style>
  .about-page { padding-top: 6.8rem; }
  .about-hero {
    display: grid;
    grid-template-columns: 1.15fr .85fr;
    gap: 2.5rem;
    align-items: center;
    padding-bottom: 1rem;
  }
  .about-kicker {
    display: inline-flex;
    padding: .35rem .65rem;
    margin: 0 0 1rem;
    background: rgba(0, 27, 32, .6);
    color: var(--primary);
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  h1 { margin: 0 0 1rem; font-size: clamp(2.2rem, 6vw, 4.5rem); line-height: 1.02; }
  h1 span { color: var(--primary); }
  p { color: var(--muted); max-width: 62ch; }
  .about-actions { display: flex; gap: .8rem; flex-wrap: wrap; margin-top: 1.25rem; }
  .about-photo {
    border-radius: .75rem;
    overflow: hidden;
    background: var(--surface-container-high);
    box-shadow: var(--ambient-shadow);
  }
  .about-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .timeline {
    position: relative;
    display: grid;
    gap: 1rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: .38rem;
    top: .6rem;
    bottom: .6rem;
    width: 1px;
    background: linear-gradient(to bottom, rgba(47, 217, 244, .55), rgba(69, 70, 77, .3));
  }
  .timeline__item {
    position: relative;
    padding-left: 1.75rem;
  }
  .timeline__dot {
    position: absolute;
    left: 0;
    top: .8rem;
    width: .75rem;
    height: .75rem;
    border-radius: 999px;
    background: var(--primary);
    box-shadow: 0 0 0 6px rgba(47, 217, 244, .1);
  }
  .timeline__dot--alt {
    background: var(--accent-ai);
    box-shadow: 0 0 0 6px rgba(123, 208, 255, .12);
  }
  .timeline__content {
    background: rgba(34, 42, 61, .45);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(69, 70, 77, .35);
    border-left: 2px solid var(--primary);
    border-radius: .6rem;
    padding: .9rem 1rem;
  }
  .timeline__content--dashed {
    border-style: dashed;
    border-left-style: solid;
  }
  .timeline__period {
    margin: 0 0 .2rem;
    font-size: .68rem;
    color: var(--primary);
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .timeline__content h3 {
    margin: 0 0 .35rem;
    font-size: 1rem;
    font-family: var(--font-display);
  }
  .timeline__content p {
    margin: 0;
    max-width: none;
    font-size: .88rem;
  }

  .about-chips { display: flex; flex-wrap: wrap; gap: .55rem; }
  .about-chips span {
    padding: .35rem .6rem;
    border-radius: .4rem;
    background: var(--surface-container-highest);
    font-size: .78rem;
    color: var(--on-surface-variant);
  }

  @media (max-width: 920px) {
    .about-hero { grid-template-columns: 1fr; }
  }
</style>
