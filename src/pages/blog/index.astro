---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const allPosts = (await getCollection('blog', (p) => (p.data.lang ?? 'pt') === 'pt' && !p.data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = allPosts[0];
const restPosts = allPosts.slice(1);
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
const categories = [...new Set(allPosts.map((p) => p.data.category).filter(Boolean))] as string[];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <SiteNav lang="pt" active="blog" />

    <main class="blog-page">
      <div class="container-wide">
        <header class="blog-header">
          <h1>Latest <span>Insights</span></h1>
          <p>Deep dives em cloud architecture, automação e engenharia de plataformas.</p>
        </header>

        <div class="blog-layout">
          <section>
            <div class="blog-filter glass">
              <span class="blog-filter-label">Quick Tags:</span>
              <div class="blog-filter-tags" id="tag-filter">
                <button class="tag tag--active" data-tag="">Todos</button>
                {allTags.slice(0, 6).map((tag) => <button class="tag" data-tag={tag}>{tag}</button>)}
              </div>
              <div class="blog-search">
                <input type="search" id="search" placeholder="Buscar artigos..." autocomplete="off" aria-label="Buscar artigos" />
              </div>
            </div>

            {featured && (
              <section class="blog-featured" aria-label="Artigo em destaque">
                <a href={`/blog/${featured.id}/`} class="blog-featured__card"
                   data-cat={featured.data.category ?? ''}
                   data-tags={(featured.data.tags ?? []).join(',')}
                   data-title={featured.data.title.toLowerCase()}
                   data-desc={(featured.data.description ?? '').toLowerCase()}>
                  <div class="blog-featured__image" aria-hidden="true">
                    {featured.data.heroImage
                      ? <img src={(featured.data.heroImage as any).src} alt="" />
                      : <div class="blog-featured__image-placeholder"><span>📝</span></div>
                    }
                  </div>
                  <div class="blog-featured__body">
                    <div class="blog-featured__meta">
                      {featured.data.category && <span class="blog-cat-badge">{featured.data.category}</span>}
                      <span class="blog-featured__reading">{featured.data.readingTime ?? '5 min de leitura'}</span>
                    </div>
                    <h2 class="blog-featured__title">{featured.data.title}</h2>
                    <p class="blog-featured__desc">{featured.data.description}</p>
                    <div class="blog-post-footer">
                      <div class="blog-author-mini">
                        <div class="blog-author-mini__avatar" aria-hidden="true">{featured.data.author?.name?.[0] ?? 'F'}</div>
                        <div>
                          <span class="blog-author-mini__name">{featured.data.author?.name ?? 'Felipe Rezende'}</span>
                          <span class="blog-author-mini__date"> · <FormattedDate date={featured.data.pubDate} /></span>
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </section>
            )}

            <ul class="blog-grid" id="post-list">
              {restPosts.map((post) => (
                <li class="blog-card"
                    data-cat={post.data.category ?? ''}
                    data-tags={(post.data.tags ?? []).join(',')}
                    data-title={post.data.title.toLowerCase()}
                    data-desc={(post.data.description ?? '').toLowerCase()}>
                  <a href={`/blog/${post.id}/`} class="blog-card__link">
                    <div class="blog-card__image" aria-hidden="true">
                      {post.data.heroImage
                        ? <img src={(post.data.heroImage as any).src} alt="" />
                        : <div class="blog-card__image-placeholder"><span>📄</span></div>
                      }
                    </div>
                    <div class="blog-card__body">
                      <div class="blog-card__meta">
                        {post.data.category && <span class="blog-cat-badge">{post.data.category}</span>}
                        {post.data.readingTime && <span class="blog-card__reading">{post.data.readingTime}</span>}
                      </div>
                      <h3 class="blog-card__title">{post.data.title}</h3>
                      <p class="blog-card__desc">{post.data.description}</p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
            <p id="no-results" class="muted" style="display:none;margin-top:2rem;text-align:center;">Nenhum artigo encontrado.</p>
          </section>

          <aside class="blog-sidebar">
            <div class="glass sidebar-card">
              <h3>Search Archives</h3>
              <input type="search" placeholder="Keywords, topics..." />
            </div>
            <div class="glass sidebar-card">
              <h3>Categories</h3>
              <ul class="sidebar-cats">
                {categories.map((cat) => (
                  <li>
                    <span>{cat}</span>
                    <strong>{allPosts.filter((p) => p.data.category === cat).length}</strong>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        </div>
        <div class="blog-archive-cta">
          <button class="btn btn--ghost" type="button">Ver Arquivo</button>
        </div>
      </div>
    </main>

    <SiteFooter lang="pt" />

    <script>
      const searchInput = document.getElementById('search') as HTMLInputElement | null;
      const tagButtons = document.querySelectorAll<HTMLButtonElement>('#tag-filter [data-tag]');
      const items = document.querySelectorAll<HTMLElement>('#post-list .blog-card');
      const featured = document.querySelector<HTMLElement>('.blog-featured__card');
      const noResults = document.getElementById('no-results');

      let activeTag = '';

      function filter() {
        const q = searchInput?.value.toLowerCase().trim() ?? '';
        let visible = 0;

        items.forEach((item) => {
          const title = item.dataset.title ?? '';
          const desc = item.dataset.desc ?? '';
          const tags = (item.dataset.tags ?? '').split(',');
          const matchesSearch = !q || title.includes(q) || desc.includes(q);
          const matchesTag = !activeTag || tags.includes(activeTag);
          const show = matchesSearch && matchesTag;
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (featured) {
          const ftitle = featured.dataset.title ?? '';
          const fdesc = featured.dataset.desc ?? '';
          const ftags = (featured.dataset.tags ?? '').split(',');
          const fmatch = (!q || ftitle.includes(q) || fdesc.includes(q)) && (!activeTag || ftags.includes(activeTag));
          (featured.closest('.blog-featured') as HTMLElement | null)?.style?.setProperty('display', fmatch ? '' : 'none');
          if (fmatch) visible++;
        }

        if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
      }

      searchInput?.addEventListener('input', filter);
      tagButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeTag = btn.dataset.tag ?? '';
          tagButtons.forEach((b) => b.classList.remove('tag--active'));
          btn.classList.add('tag--active');
          filter();
        });
      });
    </script>
  </body>
</html>

<style>
  .blog-page {
    padding-top: 7rem;
    padding-bottom: 4.5rem;
  }
  .blog-header { margin-bottom: 2rem; }
  .blog-header h1 { margin: 0 0 .65rem; font-size: clamp(2.2rem, 5vw, 4.5rem); }
  .blog-header h1 span { color: var(--primary); font-style: italic; }
  .blog-header p { margin: 0; color: var(--muted); }

  .blog-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 1.25rem;
  }
  .glass {
    background: rgba(34, 42, 61, 0.45);
    backdrop-filter: blur(20px);
    border-radius: .75rem;
    outline: 1px solid var(--border);
  }
  .blog-filter {
    display: flex;
    justify-content: space-between;
    gap: .9rem;
    padding: .9rem;
    margin-bottom: 1.2rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .blog-filter-label {
    font-size: .62rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    font-family: var(--font-display);
    margin-right: .35rem;
  }
  .blog-filter-tags { display: flex; gap: .45rem; flex-wrap: wrap; }
  .blog-search { min-width: 250px; }

  .blog-sidebar { display: grid; gap: .9rem; align-content: start; }
  .sidebar-card { padding: 1rem; }
  .sidebar-card h3 { margin: 0 0 .8rem; font-size: .95rem; }
  .sidebar-card ul { list-style: none; margin: 0; padding: 0; display: grid; gap: .45rem; }
  .sidebar-card li { color: var(--muted); font-size: .88rem; }
  .sidebar-cats li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(23, 31, 51, .45);
    border: 1px solid rgba(69, 70, 77, .25);
    border-radius: .45rem;
    padding: .45rem .55rem;
  }
  .sidebar-cats li strong {
    color: var(--primary);
    font-size: .68rem;
    letter-spacing: .06em;
  }
  .sidebar-card input {
    width: 100%;
    border: none;
    border-radius: .4rem;
    padding: .7rem .8rem;
    background: var(--surface-container-highest);
    color: var(--muted);
  }
  .blog-archive-cta {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1100px) {
    .blog-layout { grid-template-columns: 1fr; }
    .blog-sidebar { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 760px) {
    .blog-sidebar { grid-template-columns: 1fr; }
  }
</style>
