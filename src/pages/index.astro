---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Card from '../components/Card.astro';
import { stack } from '../data/stack';
import { SITE_TITLE } from '../consts';
import LanguageToggle from '../components/LanguageToggle.astro';

const lang = 'pt';

const posts = (await getCollection('blog', (p) => (p.data.lang ?? 'pt') === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const projects = (await getCollection('projects', (p) => (p.data.lang ?? 'pt') === lang))
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const certs = (await getCollection('certifications', (c) => (c.data.lang ?? 'pt') === lang))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<html lang="pt-BR">
  <head>
    <BaseHead title={SITE_TITLE} description="Portfólio e blog de estudos de DevOps." />
  </head>
  <body>
    <main class="container">
      <header class="topbar">
        <nav class="topbar__nav">
          <a class="topbar__brand" href="/">Felipe Rezende</a>
          <div class="topbar__links">
            <a href="#projetos">Projetos</a>
            <a href="#certificacoes">Certificações</a>
            <a href="#stack">Stack</a>
            <a href="#contato">Contato</a>
            <LanguageToggle />
          </div>
        </nav>
      </header>

      <section class="hero">
        <p class="muted">DevOps Engineer</p>
        <h1>Construindo infraestrutura confiável, automatizada e observável.</h1>
        <p class="hero__subtitle">
          Aqui eu registro estudos e compartilho projetos sobre cloud, IaC, CI/CD, Kubernetes e observabilidade.
        </p>

        <div class="hero__actions">
          <a class="btn" href="/blog/">Ler artigos</a>
          <a class="btn btn--ghost" href="#contato">Contato</a>
        </div>

        <div class="hero__meta">
          <a href="https://github.com/rezendesfelipe">GitHub</a>
          <span aria-hidden="true">·</span>
          <a href="https://www.linkedin.com/in/SEU_LINKEDIN/">LinkedIn</a>
          <span aria-hidden="true">·</span>
          <a href="mailto:SEU_EMAIL_AQUI">Email</a>
        </div>
      </section>

      <section class="section" id="projetos">
        <div class="section__header">
          <h2>Projetos</h2>
        </div>

        <div class="grid">
          {projects.map((p) => (
            <Card href={p.data.url}>
              <h3 class="card__title">{p.data.title}</h3>
              <p class="muted">{p.data.description}</p>
              {p.data.tags?.length ? (
                <ul class="tags">
                  {p.data.tags.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
              ) : null}
            </Card>
          ))}
        </div>
      </section>

      <section class="section" id="certificacoes">
        <div class="section__header">
          <h2>Certificações</h2>
        </div>

        <div class="grid">
          {certs.map((c) => (
            <Card href={c.data.url}>
              <h3 class="card__title">{c.data.title}</h3>
              <p class="muted">{c.data.issuer}</p>
            </Card>
          ))}
        </div>
      </section>

      <section class="section" id="stack">
        <div class="section__header">
          <h2>{stack.pt.title}</h2>
        </div>

        <div class="grid grid--stack">
          {stack.pt.items.map((i) => (
            <Card>
              <h3 class="card__title">{i.label}</h3>
              <p class="muted">{i.value}</p>
            </Card>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="section__header">
          <h2>Últimos artigos</h2>
          <a class="link" href="/blog/">Ver todos</a>
        </div>

        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <h3>{post.data.title}</h3>
                <p class="muted">{post.data.description}</p>
                <p class="muted"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="section" id="contato">
        <div class="section__header">
          <h2>Contato</h2>
        </div>

        <div class="grid">
          <Card href="mailto:frezende21@gmail.com">
            <h3 class="card__title">Email</h3>
            <p class="muted">frezende21@gmail.com</p>
          </Card>
          <Card href="https://www.linkedin.com/in/rezendesfelipe/">
            <h3 class="card__title">LinkedIn</h3>
            <p class="muted">Conecte comigo</p>
          </Card>
          <Card href="https://github.com/rezendesfelipe">
            <h3 class="card__title">GitHub</h3>
            <p class="muted">@rezendesfelipe</p>
          </Card>
        </div>
      </section>

      <footer class="footer">
        <p class="muted">© {new Date().getFullYear()} Felipe Rezende</p>
      </footer>
    </main>
  </body>
</html>