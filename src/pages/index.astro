---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Card from '../components/Card.astro';
import { arsenal } from '../data/stack';
import ArsenalCard from '../components/ArsenalCard.astro';
import { SITE_TITLE } from '../consts';
import LanguageToggle from '../components/LanguageToggle.astro';
import logo from '../assets/logo_variation_4.png';

const lang = 'pt';

const posts = (await getCollection('blog', (p) => (p.data.lang ?? 'pt') === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const projects = (await getCollection('projects', (p) => (p.data.lang ?? 'pt') === lang))
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const certs = (await getCollection('certifications', (c) => (c.data.lang ?? 'pt') === lang))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<html lang="pt-BR">
  <head>
    <BaseHead title={SITE_TITLE} description="Portfólio e blog de estudos de DevOps e Cloud." />
  </head>
  <body>
    <header class="topbar">
      <nav class="topbar__nav">
        <a class="topbar__brand" href="/"><img src={logo.src} alt="Felipe Rezende" class="topbar__logo" /></a>
        <div class="topbar__links">
          <a href="#certificacoes">Certificações</a>
          <a href="#arsenal">Arsenal Técnico</a>
          <a href="/blog/">Blog</a>
          <LanguageToggle />
        </div>
      </nav>
    </header>

    <main class="container">
      <!-- ── Section 1: Hero ── -->
      <section class="hero">
        <div class="hero__inner">
          <div class="hero__content">
            <h1 class="hero__name"><span>Felipe Rezende</span></h1>
            <p class="hero__role">Cloud and DevOps Architect</p>
            <p class="hero__about">
              Especialista em infraestrutura cloud, automação e observabilidade.
              Apaixonado por transformar ambientes complexos em sistemas confiáveis,
              escaláveis e bem documentados — com AWS, Azure, Terraform, Kubernetes e muito mais.
            </p>
            <div class="hero__social">
              <a href="https://github.com/rezendesfelipe" target="_blank" rel="noopener" aria-label="GitHub">
                <!-- Lucide: github -->
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                  <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
              </a>
              <a href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener" aria-label="LinkedIn">
                <!-- Lucide: linkedin -->
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect width="4" height="12" x="2" y="9"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
              <a href="mailto:frezende21@gmail.com" aria-label="Email">
                <!-- Lucide: mail -->
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </a>
            </div>
          </div>
          <div class="hero__photo" aria-label="Foto de Felipe Rezende">
            <img src="/profile.jpg" alt="Felipe Rezende" />
          </div>
        </div>
      </section>

      <!-- ── Section: Certificações ── -->
      <section class="section" id="certificacoes">
        <div class="section__header">
          <h2>Certificações</h2>
        </div>

        <div class="grid">
          {certs.map((c) => (
            <Card href={c.data.url}>
              <h3 class="card__title">{c.data.title}</h3>
              <p class="muted card__desc">{c.data.issuer}</p>
            </Card>
          ))}
        </div>
      </section>

      <!-- ── Section: Arsenal Técnico ── -->
      <section class="section" id="arsenal">
        <div class="section__header">
          <h2>{arsenal.pt.title}</h2>
        </div>

        <div class="grid grid--stack">
          {arsenal.pt.categories.map((cat) => (
            <ArsenalCard
              icon={cat.icon}
              label={cat.label}
              subtitle={cat.subtitle}
              items={cat.items}
              highlight={cat.highlight}
            />
          ))}
        </div>
      </section>

      <!-- ── Section: Artigos Recentes ── -->
      <section class="section">
        <div class="section__header">
          <h2>Artigos Recentes</h2>
          <a class="link" href="/blog/">Ver todos →</a>
        </div>

        <ul class="home-posts-grid">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="blog-card__link">
                <div class="blog-card__image" aria-hidden="true">
                  {post.data.heroImage
                    ? <img src={(post.data.heroImage as any).src} alt="" />
                    : <div class="blog-card__image-placeholder"><span>📄</span></div>
                  }
                </div>
                <div class="blog-card__body">
                  {post.data.category && (
                    <div class="blog-card__meta">
                      <span class="blog-cat-badge">{post.data.category}</span>
                      {post.data.readingTime && <span class="blog-card__reading">{post.data.readingTime}</span>}
                    </div>
                  )}
                  <h3 class="blog-card__title">{post.data.title}</h3>
                  <p class="blog-card__desc">{post.data.description}</p>
                  <div class="blog-post-footer">
                    <div class="blog-author-mini">
                      <div class="blog-author-mini__avatar" aria-hidden="true">
                        {post.data.author?.name?.[0] ?? 'F'}
                      </div>
                      <div>
                        <span class="blog-author-mini__name">{post.data.author?.name ?? 'Felipe Rezende'}</span>
                        <span class="blog-author-mini__date"> · <FormattedDate date={post.data.pubDate} /></span>
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>

    <!-- ── Footer ── -->
    <footer class="footer container">
      <div class="footer__grid">
        <div>
          <p class="footer__brand-name">Felipe Rezende</p>
          <p class="footer__tagline">Cloud and DevOps Architect.<br/>Construindo infraestrutura confiável.</p>
        </div>
        <div>
          <p class="footer__col-title">Navegação</p>
          <ul class="footer__links">
            <li><a href="/">Início</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="#case-studies">Estudos de Caso</a></li>
            <li><a href="#certificacoes">Certificações</a></li>
          </ul>
        </div>
        <div>
          <p class="footer__col-title">Conteúdo</p>
          <ul class="footer__links">
            <li><a href="/blog/">Artigos</a></li>
            <li><a href="#arsenal">Arsenal Técnico</a></li>
            <li><a href="/rss.xml">RSS Feed</a></li>
            <li><a href="/sitemap-index.xml">Sitemap</a></li>
          </ul>
        </div>
        <div>
          <p class="footer__col-title">Contato</p>
          <ul class="footer__links footer__links--icons">
            <li>
              <a href="https://github.com/rezendesfelipe" target="_blank" rel="noopener" aria-label="GitHub">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                  <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
              </a>
            </li>
            <li>
              <a href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect width="4" height="12" x="2" y="9"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
            </li>
            <li>
              <a href="mailto:frezende21@gmail.com" aria-label="Email">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="footer__bottom">
        <p class="footer__copy">© {new Date().getFullYear()} Felipe Rezende. Todos os direitos reservados.</p>
        <span class="footer__made">feito com <a href="https://astro.build" target="_blank" rel="noopener">astro</a></span>
      </div>
    </footer>
  </body>
</html>
