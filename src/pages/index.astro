---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const featuredProjects = projects.filter((p) => p.data.featured).slice(0, 6);
---

<html lang="pt-BR">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <main class="container">
      <section class="hero">
        <p class="hero__kicker">Olá, eu sou</p>
        <h1 class="hero__title">Felipe Rezende</h1>
        <p class="hero__subtitle">
          Portfólio e blog sobre estudos (cloud, dev, arquitetura e o que eu estiver aprendendo).
        </p>

        <div class="hero__actions">
          <a class="btn" href="/about/">Sobre</a>
          <a class="btn btn--ghost" href="/blog/">Ler posts</a>
          <a class="btn btn--ghost" href="#projetos">Projetos</a>
        </div>

        <div class="hero__links">
          <a href="https://github.com/rezendesfelipe">GitHub</a>
          <span aria-hidden="true">·</span>
          <a href="mailto:SEU_EMAIL_AQUI">Email</a>
          <span aria-hidden="true">·</span>
          <a href="https://www.linkedin.com/in/SEU_LINKEDIN/">LinkedIn</a>
        </div>
      </section>

      <section class="section" aria-labelledby="sobre">
        <h2 id="sobre">Sobre</h2>
        <p class="muted">
          Eu registro aqui meus estudos e projetos, com foco em aprendizado contínuo e prática.
          A ideia é documentar de forma simples e reaproveitável.
        </p>
      </section>

      <section class="section" id="projetos" aria-labelledby="projetos-title">
        <div class="section__header">
          <h2 id="projetos-title">Projetos</h2>
          <p class="muted">Algumas coisas que eu construí / estou construindo.</p>
        </div>

        <div class="grid">
          {featuredProjects.map((p) => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              url={p.data.url}
              tags={p.data.tags}
            />
          ))}
        </div>
      </section>

      <section class="section" aria-labelledby="posts-title">
        <div class="section__header">
          <h2 id="posts-title">Posts recentes</h2>
          <a class="link" href="/blog/">Ver todos</a>
        </div>

        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <h3>{post.data.title}</h3>
                <p class="muted">{post.data.description}</p>
                <p class="muted">
                  <FormattedDate date={post.data.pubDate} />
                </p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>