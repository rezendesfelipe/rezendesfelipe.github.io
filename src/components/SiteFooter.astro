---
interface Props {
  lang?: 'pt' | 'en';
}

const { lang = 'pt' } = Astro.props;

const base = lang === 'en' ? '/en' : '';
const copy = lang === 'en'
  ? 'All rights reserved.'
  : 'Todos os direitos reservados.';
const labels = {
  sitemap: lang === 'en' ? 'Sitemap' : 'Mapa do Site',
  social: lang === 'en' ? 'Social' : 'Redes',
  home: lang === 'en' ? 'Home' : 'Início',
  about: lang === 'en' ? 'About' : 'Sobre',
  blog: 'Blog',
  contact: lang === 'en' ? 'Contact' : 'Contato',
};
---

<footer class="footer container-wide">
  <div class="footer__grid">
    <div>
      <p class="footer__brand-name" style="font-size:1.2rem;color:var(--primary);font-family:var(--font-display);letter-spacing:-.03em;">Felipe Rezende</p>
      <p class="footer__tagline">Rio de Janeiro, Brazil [UTC-3]</p>
    </div>

    <div>
      <p class="footer__col-title">{labels.sitemap}</p>
      <ul class="footer__links">
        <li><a href={lang === 'en' ? '/en/' : '/'}>{labels.home}</a></li>
        <li><a href={`${base}/about/`}>{labels.about}</a></li>
        <li><a href={`${base}/blog/`}>{labels.blog}</a></li>
        <li><a href={`${base}/contact/`}>{labels.contact}</a></li>
      </ul>
    </div>

    <div>
      <p class="footer__col-title">{labels.social}</p>
      <ul class="footer__links footer__links--icons">
        <li>
          <a href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="currentColor">
              <path d="M4.98 3.5C4.98 4.88 3.86 6 2.48 6S0 4.88 0 3.5 1.12 1 2.48 1s2.5 1.12 2.5 2.5zM.5 8h4V24h-4V8zm7 0h3.83v2.19h.05C11.91 9.14 13.64 8 16.1 8 21.09 8 22 11.27 22 15.52V24h-4v-7.61c0-1.81-.03-4.14-2.52-4.14-2.52 0-2.9 1.97-2.9 4.01V24h-4V8z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="https://github.com/rezendesfelipe" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="currentColor">
              <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2.02c-3.2.7-3.88-1.36-3.88-1.36-.53-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.04 1.77 2.72 1.26 3.38.97.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.28 1.18-3.08-.12-.3-.5-1.5.11-3.14 0 0 .96-.31 3.15 1.17a10.9 10.9 0 0 1 5.74 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.64.24 2.84.12 3.14.74.8 1.18 1.82 1.18 3.08 0 4.43-2.7 5.4-5.28 5.68.41.35.78 1.05.78 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <div style="text-align:right;">
      <p class="footer__copy">© {new Date().getFullYear()} Felipe Rezende. {copy}</p>
    </div>
  </div>

  <div class="footer__bottom">
    <span class="footer__made">cloud • devops • automation</span>
  </div>
</footer>
