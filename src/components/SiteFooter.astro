---
interface Props {
  lang?: 'pt' | 'en';
}

const { lang = 'pt' } = Astro.props;

const base = lang === 'en' ? '/en' : '';
const copy = lang === 'en'
  ? 'All rights reserved.'
  : 'Todos os direitos reservados.';
const builtText = lang === 'en' ? 'Built for the Neon Architect.' : 'Construído para o Neon Architect.';
---

<footer class="footer container-wide">
  <div class="footer__bottom" style="margin-top:0;padding-top:0;border-top:none;">
    <div>
      <p class="footer__brand-name" style="font-size:1.2rem;color:var(--primary);font-family:var(--font-display);letter-spacing:-.03em;">FR</p>
      <p class="footer__tagline">Rio de Janeiro, Brazil [UTC-3]</p>
    </div>
    <ul class="footer__links" style="flex-direction:row;gap:1.2rem;flex-wrap:wrap;">
      <li><a href="https://www.linkedin.com/in/rezendesfelipe/" target="_blank" rel="noopener">LinkedIn</a></li>
      <li><a href="https://github.com/rezendesfelipe" target="_blank" rel="noopener">GitHub</a></li>
      <li><a href={`${base}/blog/`}>Blog</a></li>
      <li><a href="/rss.xml">RSS</a></li>
      <li><a href="/sitemap-index.xml">Sitemap</a></li>
    </ul>
    <div style="text-align:right;">
      <p class="footer__copy">© {new Date().getFullYear()} Felipe Rezende. {copy}</p>
      <span class="footer__made">{builtText}</span>
    </div>
  </div>
</footer>
