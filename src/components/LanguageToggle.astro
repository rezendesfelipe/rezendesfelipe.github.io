---
const pathname = Astro.url.pathname;

// Normalize: remove trailing slash exceto root
const normalized = pathname !== '/' ? pathname.replace(/\/$/, '') : '/';

function toEN(path: string) {
  if (path === '/') return '/en/';
  if (path.startsWith('/en')) return path; // já é EN
  return `/en${path}${path.endsWith('/') ? '' : '/'}`;
}

function toPT(path: string) {
  if (path === '/en' || path === '/en/') return '/';
  if (path.startsWith('/en/')) return path.replace(/^\/en/, '') || '/';
  return path;
}

const isEN = normalized === '/en' || normalized.startsWith('/en/');
const targetHref = isEN ? toPT(pathname) : toEN(pathname);
const aria = isEN ? 'Mudar para Português' : 'Switch to English';
---

<a class={`lang-switch${isEN ? ' lang-switch--en' : ''}`} href={targetHref} aria-label={aria} title={aria}>
  <span class="lang-switch__label lang-switch__label--pt">PT</span>
  <span class="lang-switch__track" aria-hidden="true">
    <span class="lang-switch__thumb"></span>
  </span>
  <span class="lang-switch__label lang-switch__label--en">EN</span>
</a>